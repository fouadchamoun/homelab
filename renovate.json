{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":dependencyDashboard",
    ":configMigration",
    ":semanticPrefixFixDepsChoreOthers",
    ":ignoreModulesAndTests",
    ":separateMajorReleases",
    ":pinVersions",
    "replacements:all",
    "workarounds:all",
    "abandonments:recommended",
    "helpers:pinGitHubActionDigests",
    "helpers:githubDigestChangelogs"
  ],
  "prHourlyLimit": 0,
  "internalChecksFilter": "strict",
  "minimumReleaseAge": "7 days",
  "argocd": {
    "managerFilePatterns": ["k8s/bootstrap/*"]
  },
  "kubernetes": {
    "managerFilePatterns": ["k8s/**/manifests/*"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update versions based on renovate comments in files",
      "managerFilePatterns": ["**/*"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>.*?)\\s*depName=(?<depName>.*?)(\\s*versioning=(?<versioning>.*?))?\\s*\\w*:\\s*(?<currentValue>.*)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ],
  "packageRules": [
    {
      "description": "Apply 30-day minimum release age for Talos and Kubernetes updates",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": [
        "siderolabs/talos",
        "kubernetes/kubernetes"
      ],
      "minimumReleaseAge": "30 days"
    },
    {
      "description": "Use date versioning for homebridge Docker image",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/homebridge/homebridge"],
      "versioning": "date"
    }
  ]
}
