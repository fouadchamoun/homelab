{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":dependencyDashboard",
    ":configMigration",
    ":semanticPrefixFixDepsChoreOthers",
    ":ignoreModulesAndTests",
    ":separateMajorReleases",
    ":separatePatchReleases",
    ":pinVersions",
    "replacements:all",
    "workarounds:all",
    "abandonments:recommended",
    "helpers:pinGitHubActionDigests",
    "helpers:githubDigestChangelogs"
  ],
  "prHourlyLimit": 0,
  "internalChecksFilter": "strict",
  "minimumReleaseAge": "7 days",
  "argocd": {
    "managerFilePatterns": ["k8s/bootstrap/*"]
  },
  "kubernetes": {
    "managerFilePatterns": ["k8s/**/*.yaml"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update versions based on renovate comments in k8s/talos/locals.tf",
      "managerFilePatterns": ["k8s/talos/locals.tf"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>.*?)\\s*depName=(?<depName>.*?)(\\s*versioning=(?<versioning>.*?))?\\s*\\s*\\w+\\s*=\\s*\"?(?<currentValue>[^\"]+)\"?"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Update debian packages based on renovate comments in files",
      "managerFilePatterns": ["**/roles/**/tasks/*"],
      "matchStrings": [
        "#\\s*renovate:\\s*(?:registry=(?<registry>\\S+)\\s+)?(?:suite=(?<suite>\\S+)\\s+)?(?:components=(?<components>\\S+)\\s+)?(?:binaryArch=(?<binaryArch>\\S+)\\s+)?-\\s*(?<depName>\\S+?)=(?<currentValue>\\S+)"
      ],
      "registryUrlTemplate": "{{#if registry}}{{registry}}{{else}}https://deb.debian.org/debian{{/if}}?suite={{#if suite}}{{suite}}{{else}}stable{{/if}}&components={{#if components}}{{components}}{{else}}main,contrib,non-free{{/if}}&binaryArch={{#if binaryArch}}{{binaryArch}}{{else}}amd64{{/if}}",
      "datasourceTemplate": "deb"
    }
  ],
  "packageRules": [
    {
      "description": "Apply 30-day minimum release age for Talos and Kubernetes updates",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": [
        "siderolabs/talos",
        "kubernetes/kubernetes"
      ],
      "minimumReleaseAge": "30 days"
    },
    {
      "description": "Use regex versioning for homebridge Docker image date tags",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["homebridge/homebridge"],
      "versioning": "regex:^(?<major>\\d{4})-(?<minor>\\d{2})-(?<patch>\\d{2})$",
      "separateMajorMinor": false,
      "separateMinorPatch": false
    },
    {
      "matchDatasources": ["deb"],
      "minimumReleaseAge": null
    },
    {
      "matchPackageNames": [
        "https://github.com/argoproj/argo-cd",
        "argo-cd"
      ],
      "groupName": "argocd"
    },
    {
      "matchDatasources": ["deb"],
      "matchPackageNames": [
        "linstor-controller",
        "linstor-satellite"
      ],
      "groupName": "linstor",
      "changelogUrl": "https://github.com/LINBIT/linstor-server/blob/master/CHANGELOG.md"
    },
    {
      "matchPackageNames": ["linstor-proxmox"],
      "changelogUrl": "https://github.com/LINBIT/linstor-proxmox/blob/master/CHANGELOG.md"
    },
    {
      "matchPackageNames": ["linstor-gui"],
      "changelogUrl": "https://github.com/LINBIT/linstor-gui/blob/main/CHANGELOG.md"
    },
    {
      "matchPackageNames": ["linstor-client"],
      "changelogUrl": "https://github.com/LINBIT/linstor-client/blob/master/CHANGELOG.md"
    }
  ]
}
